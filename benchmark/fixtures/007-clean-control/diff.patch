+def truncate(text, limit):
+    """Return `text` shortened to at most `limit` characters, with an ellipsis."""
+    if limit <= 0:
+        return ""
+    if len(text) <= limit:
+        return text
+    return text[: max(0, limit - 1)].rstrip() + "\u2026"
